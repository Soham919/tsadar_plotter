Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "\"\<Global`*\>\"", "]"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Constants", " ", "in", " ", "SI"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"me", "=", 
   RowBox[{"9.1093837015", "*", 
    RowBox[{"10", "^", 
     RowBox[{"-", "31"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"e", " ", "=", " ", 
   RowBox[{"1.6", "*", 
    RowBox[{"10", "^", 
     RowBox[{"-", "19"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"kB", "=", 
   RowBox[{"1.380649", "*", 
    RowBox[{"10", "^", 
     RowBox[{"-", "23"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"h", "=", 
   RowBox[{"6.62607015", "*", 
    RowBox[{"10", "^", 
     RowBox[{"-", "34"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"X", "=", 
    RowBox[{"13.6", "*", "e"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"ionization", " ", "potential"}], "*)"}]}], "\[IndentingNewLine]", 

 RowBox[{
  RowBox[{
   RowBox[{"d", " ", "=", " ", "1"}], ";"}], "  ", 
  RowBox[{"(*", "degeneracy", "*)"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"sahaRHS", "[", 
     RowBox[{
      RowBox[{"T_", "?", "NumericQ"}], ",", 
      RowBox[{"n_", "?", "NumericQ"}], ",", " ", "X_", ",", " ", "d_"}], 
     "]"}], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "/", "n"}], ")"}], "*", "d", "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", " ", "Pi", " ", "me", " ", "T", " ", "e"}], ")"}], "^", 
        
        RowBox[{"(", 
         RowBox[{"3", "/", "2"}], ")"}]}], "/", 
       RowBox[{"h", "^", "3"}]}], ")"}], "*", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "X"}], "/", 
       RowBox[{"(", 
        RowBox[{"T", " ", "e"}], ")"}]}], "]"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Ion", "[", 
     RowBox[{
      RowBox[{"T_", "?", "NumericQ"}], ",", 
      RowBox[{"n_", "?", "NumericQ"}], ",", " ", "X_", ",", " ", "d_"}], 
     "]"}], ":=", 
    RowBox[{"x", "/.", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"NSolve", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"x", "^", "2"}], "/", 
             RowBox[{"(", 
              RowBox[{"1", "-", "x"}], ")"}]}], "==", 
            RowBox[{"sahaRHS", "[", 
             RowBox[{"T", ",", "n", ",", "X", ",", "d"}], "]"}]}], ",", 
           RowBox[{"0", "<=", "x", "<=", "1"}]}], "}"}], ",", "x"}], "]"}], 
       "[", 
       RowBox[{"[", "1", "]"}], "]"}], ")"}]}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"densities", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"10", "^", "18"}], ",", 
      RowBox[{"10", "^", "19"}], ",", 
      RowBox[{"10", "^", "20"}]}], "}"}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"densities", " ", "in", " ", 
    RowBox[{"cm", "^", 
     RowBox[{"-", "3"}]}]}], "*)"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "@", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Ion", "[", 
       RowBox[{"T", ",", "n", ",", " ", "X", ",", " ", "d"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", 
        RowBox[{"densities", "*", 
         RowBox[{"10", "^", "6"}]}]}], "}"}]}], "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"T", ",", "0.1", ",", "50"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"Placed", "[", 
     RowBox[{
      RowBox[{"LineLegend", "[", 
       RowBox[{
        RowBox[{"densities", "/", 
         RowBox[{"10", "^", "18"}]}], ",", 
        RowBox[{"LegendLabel", "->", "\"\<n (10^18 cm^-3)\>\""}]}], "]"}], 
      ",", "Right"}], "]"}]}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<T (eV)\>\"", ",", "\"\<x\>\""}], "}"}]}], ",", 
   RowBox[{
   "PlotLabel", "->", "\"\<Saha Ionization Fraction for Hydrogen\>\""}], ",", 
   
   RowBox[{"ImageSize", "->", "Large"}]}], 
  "]"}], "\[IndentingNewLine]"}], "Input",
