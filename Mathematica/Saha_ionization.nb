Cell[BoxData[{
 RowBox[{
  RowBox[{"XHe2", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"24.6", " ", "+", " ", "54.17"}], ")"}], "*", "e"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"d", " ", "=", " ", "1"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Ion2", "[", 
     RowBox[{
      RowBox[{"T_", "?", "NumericQ"}], ",", 
      RowBox[{"n_", "?", "NumericQ"}], ",", " ", "X_", ",", " ", "d_"}], 
     "]"}], ":=", 
    RowBox[{"x", "/.", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"NSolve", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"2", " ", 
               RowBox[{"x", "^", "2"}]}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{"1", "-", "x"}], ")"}]}], "==", 
            RowBox[{"sahaRHS", "[", 
             RowBox[{"T", ",", "n", ",", "X", ",", "d"}], "]"}]}], ",", 
           RowBox[{"0", "<=", "x", "<=", "1"}]}], "}"}], ",", "x"}], "]"}], 
       "[", 
       RowBox[{"[", "1", "]"}], "]"}], ")"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"densities", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"10", "^", "18"}], ",", 
      RowBox[{"10", "^", "19"}], ",", 
      RowBox[{"10", "^", "20"}]}], "}"}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"densities", " ", "in", " ", 
    RowBox[{"cm", "^", 
     RowBox[{"-", "3"}]}]}], "*)"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "@", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Ion2", "[", 
       RowBox[{"T", ",", "n", ",", " ", "XHe2", ",", " ", "d"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", 
        RowBox[{"densities", "*", 
         RowBox[{"10", "^", "6"}]}]}], "}"}]}], "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"T", ",", "0.1", ",", "50"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"Placed", "[", 
     RowBox[{
      RowBox[{"LineLegend", "[", 
       RowBox[{
        RowBox[{"densities", "/", 
         RowBox[{"10", "^", "18"}]}], ",", 
